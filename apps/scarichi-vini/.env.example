# Supabase — variabili obbligatorie per il runtime frontend
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# AI Assistant (server-side su Cloudflare Pages Functions)
# NON presente come codice in questo clone (nessuna directory functions/ o api/).
# Variabili da definire solo se e quando il backend AI verrà implementato.
# NON esporre OPENAI_API_KEY nel frontend.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
VITE_OPENAI_MODEL=gpt-4.1-mini

# Google Sheets sync (server-side, non implementato nel frontend)
# Il canale reale è il trigger DB Supabase → Apps Script via webhook.
# Variabili da definire solo se si implementa un backend aggiuntivo.
GOOGLE_SHEETS_SPREADSHEET_ID=
